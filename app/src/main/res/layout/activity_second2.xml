<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".pertemuan_2.SecondActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KALKULATOR BANGUN"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp"
                android:background="#2C3E50"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔺 LUAS SEGITIGA"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E91E63"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/inputAlas"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Alas (cm)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/inputTinggiSegitiga"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Tinggi (cm)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnHitungSegitiga"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="HITUNG LUAS"
                android:backgroundTint="#E91E63"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/hasilSegitiga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hasil: -"
                android:padding="12dp"
                android:background="#FCE4EC"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📦 VOLUME BALOK"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_marginTop="24dp"/>

            <EditText
                android:id="@+id/inputPanjang"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Panjang (cm)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/inputLebar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Lebar (cm)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/inputTinggiBalok"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Tinggi (cm)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnHitungBalok"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="HITUNG VOLUME"
                android:backgroundTint="#2196F3"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/hasilBalok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hasil: -"
                android:padding="12dp"
                android:background="#E3F2FD"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>